<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>before the kettle's even on</title>
<style>
  :root{
    --sky-top:#cfd6ef;
    --sky-mid:#f3d9d0;
    --sky-bottom:#fff6ec;
    --ink:#4a3026;
    --accent:#b5613f;
    --accent-deep:#7c3f44;
    --cream:#fff8ee;
    --line:rgba(124,63,68,0.28);
    --font-display:'Iowan Old Style','Palatino Linotype','Book Antiqua',Georgia,serif;
    --font-body:-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
  }

  *{box-sizing:border-box;}

  html,body{
    margin:0;
    height:100%;
    background:linear-gradient(180deg, var(--sky-top) 0%, var(--sky-mid) 48%, var(--sky-bottom) 100%);
    font-family:var(--font-body);
    color:var(--ink);
    overflow-x:hidden;
  }

  .wrap{
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:2rem 1.25rem;
    position:relative;
  }

  /* soft sunrise glow behind the scene */
  .glow{
    position:absolute;
    top:14%;
    left:50%;
    width:420px;
    height:420px;
    transform:translateX(-50%);
    background:radial-gradient(circle, rgba(255,205,150,0.55) 0%, rgba(255,205,150,0) 70%);
    filter:blur(2px);
    pointer-events:none;
  }

  .card{
    position:relative;
    z-index:1;
    max-width:480px;
    width:100%;
    text-align:center;
  }

  .eyebrow{
    font-size:0.72rem;
    letter-spacing:0.22em;
    text-transform:uppercase;
    color:var(--accent-deep);
    margin-bottom:1.6rem;
    opacity:0.85;
  }

  /* ---- teacup + steam, the signature element ---- */
  .cupWrap{
    width:170px;
    margin:0 auto 1.6rem;
    position:relative;
    height:170px;
  }

  .cupWrap svg{ width:100%; height:100%; display:block; }

  .steamLine, .steamHeart{
    transform-origin:center bottom;
  }

  @media (prefers-reduced-motion: no-preference){
    .steamLine{ animation:rise 3.2s ease-in-out infinite; }
    .steamLine:nth-child(2){ animation-delay:0.5s; }
    .steamLine:nth-child(3){ animation-delay:1s; }

    .steamHeart{ animation:riseHeart 2.6s ease-in infinite; opacity:0; }
    .steamHeart:nth-child(2){ animation-delay:0.6s; }
    .steamHeart:nth-child(3){ animation-delay:1.2s; }
  }

  @keyframes rise{
    0%{ transform:translateY(0) scaleY(0.9); opacity:0; }
    25%{ opacity:0.55; }
    50%{ transform:translateY(-14px) scaleY(1.05); opacity:0.4; }
    100%{ transform:translateY(-30px) scaleY(1.1); opacity:0; }
  }

  @keyframes riseHeart{
    0%{ transform:translateY(4px) scale(0.4) rotate(-4deg); opacity:0; }
    20%{ opacity:0.9; }
    60%{ transform:translateY(-34px) scale(0.75) rotate(3deg); opacity:0.7; }
    100%{ transform:translateY(-58px) scale(0.55) rotate(-2deg); opacity:0; }
  }

  .steamHearts{ display:none; }
  .is-yes .steamLines{ display:none; }
  .is-yes .steamHearts{ display:block; }

  h1{
    font-family:var(--font-display);
    font-weight:500;
    font-size:clamp(1.45rem, 4vw + 0.7rem, 2.15rem);
    line-height:1.35;
    margin:0 0 1.1rem;
    color:var(--ink);
  }

  .sub{
    font-size:0.98rem;
    line-height:1.6;
    color:var(--ink);
    opacity:0.82;
    margin:0 auto 0;
    max-width:380px;
  }

  /* ---- buttons + the roaming "no" ---- */
  .stage{
    position:relative;
    min-height:170px;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:14px;
    margin-top:2.1rem;
    flex-wrap:wrap;
  }

  .btn{
    font-family:var(--font-body);
    font-size:0.95rem;
    font-weight:600;
    padding:0.85rem 1.9rem;
    border-radius:999px;
    cursor:pointer;
    border:none;
    white-space:nowrap;
  }

  .btn:focus-visible{
    outline:2px solid var(--accent-deep);
    outline-offset:3px;
  }

  .yes{
    background:var(--accent);
    color:var(--cream);
    box-shadow:0 8px 20px rgba(181,97,63,0.35);
    transition:transform 0.15s ease, box-shadow 0.15s ease;
  }
  .yes:hover{ transform:translateY(-2px); box-shadow:0 12px 24px rgba(181,97,63,0.45); }

  .no{
    background:transparent;
    color:var(--accent-deep);
    border:1.5px solid var(--line);
    transition:left 0.15s ease, top 0.15s ease, transform 0.15s ease;
  }

  /* ---- reveal panels ---- */
  .panel{ display:none; }
  .panel.active{ display:block; }
  .ask.active ~ .panel,
  .ask{ }

  #ask.hidden{ display:none; }

  #yesPanel h1{ margin-bottom:0.7rem; }
  #yesPanel .sub{ max-width:340px; }

  .edit-hint{
    font-size:0.78rem;
    color:var(--accent-deep);
    opacity:0.75;
    margin-top:1.3rem;
    font-style:italic;
  }

  .placeholder{
    color:var(--accent-deep);
    font-style:italic;
  }

  /* ---- shayari ---- */
  .shayari{
    font-family:var(--font-display);
    font-size:1.05rem;
    line-height:1.85;
    color:var(--ink);
    margin:0 auto 0.5rem;
    max-width:340px;
  }
  .shayari-gloss{
    font-size:0.78rem;
    color:var(--accent-deep);
    opacity:0.7;
    font-style:italic;
    margin:0 auto 1.6rem;
    max-width:320px;
  }

  /* ---- date picker ---- */
  .pickWrap{
    margin:1.5rem auto 0;
    max-width:320px;
  }
  .pickLabel{
    display:block;
    font-size:0.78rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--accent-deep);
    opacity:0.8;
    margin-bottom:0.55rem;
  }
  #dateInput{
    font-family:var(--font-body);
    font-size:1rem;
    width:100%;
    padding:0.7rem 1rem;
    border-radius:14px;
    border:1.5px solid var(--line);
    background:var(--cream);
    color:var(--ink);
    text-align:center;
  }
  #dateInput:focus-visible{
    outline:2px solid var(--accent-deep);
    outline-offset:2px;
  }

  .dateConfirm{
    min-height:1.4rem;
    font-size:0.92rem;
    color:var(--accent-deep);
    margin-top:0.8rem;
    opacity:0;
    transition:opacity 0.25s ease;
  }
  .dateConfirm.show{ opacity:1; }

  .whatsappNote{
    font-size:0.85rem;
    opacity:0.75;
    margin-top:1.4rem;
  }

  /* ---- falling confetti on yes ---- */
  .confetti{
    position:fixed;
    inset:0;
    pointer-events:none;
    overflow:hidden;
    z-index:5;
  }
  .petal{
    position:absolute;
    top:-40px;
    font-size:1.1rem;
    opacity:0;
    will-change:transform, opacity;
  }
  @media (prefers-reduced-motion: no-preference){
    .petal.fall{ animation:fall linear forwards; }
  }
  @keyframes fall{
    0%{ transform:translateY(0) translateX(0) rotate(0deg); opacity:0; }
    8%{ opacity:0.9; }
    100%{ transform:translateY(110vh) translateX(var(--drift,20px)) rotate(220deg); opacity:0; }
  }
</style>
</head>
<body>

<div class="wrap">
  <div class="glow"></div>

  <div class="card" id="card">

    <!-- ============ ASK ============ -->
    <div id="ask">
      <div class="eyebrow">before the kettle's even on</div>

      <div class="cupWrap">
        <svg viewBox="0 0 170 170" id="cupSvg">
          <!-- saucer -->
          <ellipse cx="85" cy="130" rx="58" ry="9" fill="none" stroke="var(--accent)" stroke-width="2.5" opacity="0.55"/>
          <!-- cup body -->
          <path d="M40 75 L50 118 Q85 128 120 118 L130 75 Z" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5"/>
          <!-- handle -->
          <path d="M130 84 Q150 84 150 99 Q150 114 130 112" fill="none" stroke="var(--accent)" stroke-width="2.5"/>
          <!-- rim -->
          <ellipse cx="85" cy="75" rx="45" ry="8" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5"/>

          <!-- ordinary steam -->
          <g class="steamLines">
            <path class="steamLine" d="M65 65 Q60 50 68 40 Q74 32 68 22" fill="none" stroke="var(--accent-deep)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
            <path class="steamLine" d="M85 65 Q80 48 88 36 Q94 27 87 16" fill="none" stroke="var(--accent-deep)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
            <path class="steamLine" d="M105 65 Q100 50 107 40 Q112 32 106 22" fill="none" stroke="var(--accent-deep)" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
          </g>

          <!-- steam that becomes hearts, once she says yes -->
          <g class="steamHearts">
            <path class="steamHeart" d="M68 55 c-3-4 -9-3 -9 2 c0 4 5 7 9 10 c4-3 9-6 9-10 c0-5 -6-6 -9-2z" fill="var(--accent)"/>
            <path class="steamHeart" d="M87 50 c-3-4 -9-3 -9 2 c0 4 5 7 9 10 c4-3 9-6 9-10 c0-5 -6-6 -9-2z" fill="var(--accent)"/>
            <path class="steamHeart" d="M106 55 c-3-4 -9-3 -9 2 c0 4 5 7 9 10 c4-3 9-6 9-10 c0-5 -6-6 -9-2z" fill="var(--accent)"/>
          </g>
        </svg>
      </div>

      <h1>I want to meet you — the way someone waits for their first cup of tea in the morning.</h1>
      <p class="sub">Here's the deal: one date, my treat. Fair warning — it might ruin you for ordinary mornings after.</p>

      <div class="stage" id="stage">
        <button class="btn yes" id="yesBtn">Yes, let's.</button>
        <button class="btn no" id="noBtn">No</button>
      </div>
    </div>

    <!-- ============ YES PANEL ============ -->
    <div class="panel" id="yesPanel">
      <div class="cupWrap">
        <svg viewBox="0 0 170 170">
          <ellipse cx="85" cy="130" rx="58" ry="9" fill="none" stroke="var(--accent)" stroke-width="2.5" opacity="0.55"/>
          <path d="M40 75 L50 118 Q85 128 120 118 L130 75 Z" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5"/>
          <path d="M130 84 Q150 84 150 99 Q150 114 130 112" fill="none" stroke="var(--accent)" stroke-width="2.5"/>
          <ellipse cx="85" cy="75" rx="45" ry="8" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5"/>
          <g>
            <path class="steamHeart" style="animation:riseHeart 2.6s ease-in infinite;" d="M68 55 c-3-4 -9-3 -9 2 c0 4 5 7 9 10 c4-3 9-6 9-10 c0-5 -6-6 -9-2z" fill="var(--accent)"/>
            <path class="steamHeart" style="animation:riseHeart 2.6s ease-in infinite; animation-delay:0.6s;" d="M87 50 c-3-4 -9-3 -9 2 c0 4 5 7 9 10 c4-3 9-6 9-10 c0-5 -6-6 -9-2z" fill="var(--accent)"/>
            <path class="steamHeart" style="animation:riseHeart 2.6s ease-in infinite; animation-delay:1.2s;" d="M106 55 c-3-4 -9-3 -9 2 c0 4 5 7 9 10 c4-3 9-6 9-10 c0-5 -6-6 -9-2z" fill="var(--accent)"/>
          </g>
        </svg>
      </div>
      <h1>Then let's pick the day.</h1>

      <p class="shayari">
        चाय की भाप में जो सुकून है,<br>
        वो सुकून तेरे ख़यालों में भी है।<br>
        मुलाक़ात की बस एक दरकार है,<br>
        बाकी सब तय, सिर्फ़ तारीख़ बता दे।
      </p>
      <p class="shayari-gloss">(the calm in the tea's warmth is the same calm I find thinking of you — everything's settled, just tell me the date)</p>

      <div class="pickWrap">
        <label class="pickLabel" for="dateInput">pick a day that works</label>
        <input type="date" id="dateInput">
        <div class="dateConfirm" id="dateConfirm"></div>
      </div>

      <p class="whatsappNote">Picked one? Just WhatsApp me the date you chose — I'll be waiting. ☕</p>
    </div>

  </div>
</div>

<div class="confetti" id="confetti"></div>

<script>
  const dateInput = document.getElementById('dateInput');
  const dateConfirm = document.getElementById('dateConfirm');

  const today = new Date();
  dateInput.min = today.toISOString().split('T')[0];

  dateInput.addEventListener('change', function(){
    if (!dateInput.value){
      dateConfirm.classList.remove('show');
      return;
    }
    const d = new Date(dateInput.value + 'T00:00:00');
    const label = d.toLocaleDateString('en-GB', { weekday:'long', day:'numeric', month:'long' });
    dateConfirm.textContent = label + ' — perfect, I\'ll be counting hours.';
    dateConfirm.classList.add('show');
  });

  const stage = document.getElementById('stage');
  const noBtn = document.getElementById('noBtn');
  const yesBtn = document.getElementById('yesBtn');
  const ask = document.getElementById('ask');
  const yesPanel = document.getElementById('yesPanel');
  const cupSvg = document.getElementById('cupSvg');
  const confetti = document.getElementById('confetti');

  const dodgeLines = ["nope","try again","so close","not that one","keep trying","still no","you wish","worth a shot though"];

  function dodge(){
    const stageRect = stage.getBoundingClientRect();
    const btnRect = noBtn.getBoundingClientRect();
    noBtn.style.position = 'absolute';
    const maxX = Math.max(8, stageRect.width - btnRect.width - 8);
    const maxY = Math.max(8, stageRect.height - btnRect.height - 8);
    const x = 8 + Math.random() * maxX;
    const y = 8 + Math.random() * maxY;
    noBtn.style.left = x + 'px';
    noBtn.style.top = y + 'px';
    noBtn.textContent = dodgeLines[Math.floor(Math.random() * dodgeLines.length)];
  }

  noBtn.addEventListener('mouseenter', dodge);
  noBtn.addEventListener('touchstart', function(e){
    e.preventDefault();
    dodge();
  }, { passive:false });

  noBtn.addEventListener('click', function(e){
    e.preventDefault();
    dodge();
  });

  yesBtn.addEventListener('click', function(){
    cupSvg.classList.add('is-yes');
    launchConfetti();
    setTimeout(function(){ showPanel(yesPanel); }, 450);
  });

  function showPanel(panel){
    ask.style.display = 'none';
    panel.classList.add('active');
  }

  function launchConfetti(){
    const hearts = ['🤍','🍵','✨'];
    for (let i = 0; i < 14; i++){
      const span = document.createElement('span');
      span.className = 'petal fall';
      span.textContent = hearts[Math.floor(Math.random()*hearts.length)];
      span.style.left = (Math.random()*100) + 'vw';
      span.style.setProperty('--drift', (Math.random()*60 - 30) + 'px');
      span.style.animationDuration = (3 + Math.random()*2) + 's';
      span.style.animationDelay = (Math.random()*0.6) + 's';
      confetti.appendChild(span);
      setTimeout(function(){ span.remove(); }, 6000);
    }
  }
</script>

</body>
</html>